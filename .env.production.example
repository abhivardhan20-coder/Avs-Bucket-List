# This is an example .env file for production.

# IMPORTANT: VITE_GAS_SECRET is a shared-secret that is visible in the browser bundle.
# For a single-user personal app this is acceptable since you are the only user.
# If you ever make the app public, implement a server-side proxy that injects the token server-side
# and never ships it to the browser.
VITE_GAS_SECRET=your_gas_secret_here

VITE_GAS_URL=your_gas_url_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_TMDB_API_KEY=your_tmdb_api_key_here
